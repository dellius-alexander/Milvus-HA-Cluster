# -- PostgreSQL Environment Variables --
# This file is used to configure the PostgreSQL service in a Docker container.
# Each variable is explained in detail based on the official PostgreSQL Docker image documentation.
# Reference: https://hub.docker.com/_/postgres

# PostgreSQL User Configuration
# PostgreSQL Version
export PG_MAJOR=17

# POSTGRES_USER: Specifies the name of the default PostgreSQL superuser.
# If not set, the default value is 'postgres'.
POSTGRES_USER=postgres
REPL_USER=repl
MILVUS_USER=milvus
HAPROXY_STATS_USER=admin

# POSTGRES_PASSWORD: Specifies the password for the PostgreSQL superuser.
# This variable is mandatory unless POSTGRES_HOST_AUTH_METHOD is set to 'trust'.
# Ensure this value is secure and not empty in production environments.
POSTGRES_PASSWORD=securepassword123
REPL_PASSWORD=securepassword123
MILVUS_PASSWORD=securepassword123
HAPROXY_STATS_PASSWORD=admin123

# PostgreSQL Database Configuration
# POSTGRES_DB: Specifies the name of the default database to be created.
# If not set, the default value is the same as POSTGRES_USER.
POSTGRES_DB=postgres

# PostgreSQL Initialization Options
# POSTGRES_INITDB_ARGS: Allows you to pass additional arguments to the `initdb` command.
# For example, you can enable checksums on data pages using "--data-checksums".
POSTGRES_INITDB_ARGS="--data-checksums"

# POSTGRES_INITDB_WALDIR: Specifies a custom directory for the transaction log (WAL).
# By default, the WAL is stored in a subdirectory of the main data directory (PGDATA).
# Uncomment and set this variable if you want to store the WAL in a different location.
# POSTGRES_INITDB_WALDIR=/path/to/waldir

# PostgreSQL Authentication Configuration
# POSTGRES_HOST_AUTH_METHOD: Specifies the authentication method for connections.
# Common values are 'trust', 'password', or 'md5'. Use 'trust' only for development.
POSTGRES_HOST_AUTH_METHOD=trust

# PostgreSQL Data Directory
# PGDATA: Specifies the location of the PostgreSQL data directory.
# By default, this is set to '/var/lib/postgresql/<version>/data' inside the container.
# Uncomment and set this variable if you want to use a custom data directory.
PGDATA_BASE=/var/lib/postgresql
PGDATA="${PGDATA_BASE}/data"


# PostgreSQL Connection Settings
# PGHOST: Specifies the hostname or IP address of the PostgreSQL server.
# This is typically set to 'localhost' for local connections.
PGHOST=10.1.0.99

# PGPORT: Specifies the port on which the PostgreSQL server listens for connections.
# The default value is 5432.
PGPORT=5432


# Additional Notes:
# - Ensure that sensitive information like POSTGRES_PASSWORD is not committed to version control.
# - Use Docker secrets or environment variable management tools for secure handling of sensitive data.
# - For production environments, consider using stronger authentication methods and secure configurations.


